pipe {
    agent any
    
    stages {
        stage('Build') {
            steps{
                sh 'mvn clean install'
            }
        }
        stage('Test') {
            steps{
                sh 'mvn test'
            }
        }
        stage('Deploy') {
            steps{
                echo 'Deploying...'
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed.'
        }
        success {
            echo 'Pipeline succeeded.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
